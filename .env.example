# Copy to .env for local runs. docker-compose reads these values too.

# --- App ---
APP_NAME=dizzaract
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins. Use explicit origins in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# --- Postgres ---
# Inside docker-compose the host is "postgres". For a host-run app (`make dev`)
# against the compose Postgres, use localhost:5433 (published port; 5432 is the
# in-container port and is often already taken on the host).
DATABASE_URL=postgresql+asyncpg://chat:chat@postgres:5432/chat

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# Used by the mock AI to simulate latency (seconds).
AI_REPLY_DELAY_SECONDS=0.3
